{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "pbi-tools: list-files",
      "type": "debugpy",
      "request": "launch",
      "module": "pbi_tools.cli",
      "args": ["list-files"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "justMyCode": true
    },
    {
      "name": "pbi-tools: FastAPI server",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "pbi_tools.server:app",
        "--reload",
        "--port", "8000"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "justMyCode": true
    },
    {
      "name": "pytest: all tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["-v", "tests/"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "justMyCode": false
    }
  ]
}
